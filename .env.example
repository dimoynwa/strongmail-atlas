DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/strongmail-tov
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/strongmail-tov_test
REDIS_URL=redis://localhost:6379/0

# Session context seeded into every ADK web session (override per session in the UI if needed)
# TEMPLATE_NAME=NFY_PASSWORD_CREATED
TEMPLATE_NAME=NFY_SM_REGISTERED
LANG_LOCAL=EN
PARAM_CUST_BRAND=SKRILL

# Default LLM provider: bedrock | bedrock_nova_pro | gemini | ollama | openai
TEMPLATE_ASSISTANT_MODEL=bedrock

# Template Assistant agents (env: TEMPLATE_ASSISTANT_{AGENT_KEY}_MODEL)
TEMPLATE_ASSISTANT_ROOT_MODEL=bedrock
TEMPLATE_ASSISTANT_RESOLUTION_MODEL=bedrock
TEMPLATE_ASSISTANT_WORKING_COPY_MODEL=bedrock
TEMPLATE_ASSISTANT_TONE_EVALUATION_MODEL=bedrock
TEMPLATE_ASSISTANT_TONE_SUGGESTION_MODEL=bedrock

# General Agent agents
TEMPLATE_ASSISTANT_GENERAL_MODEL=bedrock
TEMPLATE_ASSISTANT_STRUCTURAL_QUERY_MODEL=bedrock
TEMPLATE_ASSISTANT_SEMANTIC_SEARCH_MODEL=bedrock
TEMPLATE_ASSISTANT_KEYWORD_SEARCH_MODEL=bedrock
TEMPLATE_ASSISTANT_TONE_DISCOVERY_MODEL=bedrock

# Bedrock model IDs — set both when mixing bedrock and bedrock_nova_pro providers
BEDROCK_MODEL=bedrock/converse/qwen.qwen3-235b-a22b-2507-v1:0
BEDROCK_MODEL_NOVA_PRO=bedrock/converse/qwen.qwen3-235b-a22b-2507-v1:0

# GEMINI_MODEL=gemini-2.5-flash-lite
# OLLAMA_MODEL=gemma3
# OLLAMA_BASE_URL=http://localhost:11434/v1

# AWS credentials for Bedrock (standard AWS SDK env vars)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# OPENAI_API_KEY=
