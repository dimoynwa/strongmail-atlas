{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Pytest integration tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: Resolution smoke test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/smoke_test_resolution.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}