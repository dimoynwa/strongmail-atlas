{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Pytest integration tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "ADK Web: Template Assistant",
            "type": "debugpy",
            "request": "launch",
            "module": "google.adk.cli",
            "args": [
                "web",
                "template_assistant",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--reload"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "TEMPLATE_NAME": "NFY_SM_REGISTERED",
                "LANG_LOCAL": "EN",
                "PARAM_CUST_BRAND": "SKRILL",
                "TEMPLATE_ASSISTANT_MODEL": "bedrock_nova_pro"
            },
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "ADK Web: General Agent",
            "type": "debugpy",
            "request": "launch",
            "module": "google.adk.cli",
            "args": [
                "web",
                "general_agent",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--reload"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: Resolution smoke test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/smoke_test_resolution.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Smoke: Change Tone",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/smoke_change_tone.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "FastAPI: Agent Studio API",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--workers",
                "1",
                "--reload"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "TEMPLATE_ASSISTANT_MODEL": "bedrock_nova_pro",
                "OTEL_SDK_DISABLED": "true"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Streamlit: Agent Studio",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/app/main.py",
                "--server.port",
                "8501"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "TEMPLATE_ASSISTANT_MODEL": "bedrock_nova_pro",
                "OTEL_SDK_DISABLED": "true"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
